{
  "expo": {
    "name": "OXXO Cargos",
    "slug": "oxxo-cargos-tienda",
    "version": "1.0.0",
    "orientation": "landscape",
    "scheme": "oxxo-cargos",
    "platforms": ["android"],
    "android": {
      "package": "com.oxxo.cargos",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "Necesitamos acceso a la cámara para escanear productos." }]
    ]
  }
}
